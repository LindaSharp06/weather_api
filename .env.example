# Copy to .env and adjust. Used for local runs; Docker Compose sets its own env.

# PostgreSQL (required for storing exchange rate data)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=weather
DB_USER=postgres
DB_PASSWORD=twin123

# Optional: full URL overrides DB_* (e.g. postgres://user:pass@host:5432/dbname)
# DATABASE_URL=postgres://postgres:twin123@localhost:5432/weather

# Fetcher script: interval in minutes (default 5) or seconds for quick testing
# FETCH_INTERVAL_MINUTES=5
# FETCH_INTERVAL_SECONDS=30

# API timeout in seconds (default 10)
# API_TIMEOUT=10
